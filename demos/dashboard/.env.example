# Public URL, used for OG Image when running nuxt generate
NUXT_PUBLIC_SITE_URL=

# Session encryption key (min 32 chars, auto-generated in dev by nuxt-auth-utils)
NUXT_SESSION_PASSWORD=

# GitHub OAuth (register at https://github.com/settings/applications/new)
# Callback URL: http://localhost:3010/auth/github
NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=
