# Core datasource — the control plane database (ADR-005)
# You must use a PostgreSQL-compatible datasource.
# Choose from existing providers or write your own.
# See: core/server/utils/config-service/provider.ts
#
# Providers: supabase, pg, neon, sqlite (planned)
CORE_DATASOURCE_URL=https://your-project.supabase.co
CORE_DATASOURCE_KEY=your-service-key
CORE_DATASOURCE_PROVIDER=supabase

# Supabase personal access token — enables `bun scripts/db-setup.ts` to
# execute SQL remotely via the Management API.
# Generate at: Supabase Dashboard → Account → Access Tokens
SUPABASE_ACCESS_TOKEN=

# Environment identifier for config service layer filtering.
# Decoupled from NODE_ENV (which is only 'development' or 'production' in Nuxt).
# Supports arbitrary values: development, staging, production, pr-123, etc.
# Falls back to NODE_ENV if not set.
CORE_ENVIRONMENT=development
