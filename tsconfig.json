{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "noEmit": true
  },
  "references": [
    { "path": "./core" },
    { "path": "./apps/admin" },
    { "path": "./apps/demo" },
    { "path": "./apps/www" }
  ],
  "files": [],
  "exclude": ["node_modules"]
}
